---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Editorial category page",
  canonicalUrl,
  ogImage = "/default-og.jpg",
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | InsightHub</title>
    <meta name="title" content={`${title} | InsightHub`} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl || Astro.url.href} />
    <meta property="og:title" content={`${title} | InsightHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl || Astro.url.href} />
    <meta property="twitter:title" content={`${title} | InsightHub`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="editorial-bg editorial-ink min-h-screen">
    <slot />
  </body>
</html>
