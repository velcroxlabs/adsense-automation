---
import { getPublishedArticles } from "../lib/content";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Your source for quality content on personal finance, home improvement, and health & wellness.",
  canonicalUrl,
  ogImage = "/default-og.jpg",
  noindex = false,
} = Astro.props as Props;

const categories = [
  { label: "Personal Finance", href: "/category/personal-finance" },
  { label: "Home Improvement", href: "/category/home-improvement" },
  { label: "Health & Wellness", href: "/category/health-wellness" },
  { label: "Executive Leadership", href: "/about" },
  { label: "Technology", href: "/stats" },
];

type FeaturedPost = {
  id: number;
  category: string;
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  author?: string;
  image: string;
  href: string;
};

const categoryLabelBySlug: Record<string, string> = {
  "personal-finance": "Personal Finance",
  "home-improvement": "Home Improvement",
  "health-wellness": "Health & Wellness",
};

const latestArticles = await getPublishedArticles(6);
const heroPost = latestArticles[0]
  ? {
      category: categoryLabelBySlug[latestArticles[0].categorySlug] ?? "Editorial",
      title: latestArticles[0].title,
      excerpt: latestArticles[0].excerpt,
      author: latestArticles[0].author,
      image: latestArticles[0].image,
      href: `/article/${latestArticles[0].slug}`,
    }
  : null;

const dbFeaturedPosts = latestArticles.slice(1).map((article, index) => ({
  id: index + 1,
  category: categoryLabelBySlug[article.categorySlug] ?? "Editorial",
  title: article.title,
  excerpt: article.excerpt,
  date: article.publishedAt
    ? new Date(article.publishedAt).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      })
    : "Recent",
  readTime: article.readTimeLabel,
  author: article.author,
  image: article.image,
  href: `/article/${article.slug}`,
}));

const featuredPosts = dbFeaturedPosts;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title} | InsightHub</title>
    <meta name="title" content={`${title} | InsightHub`} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl || Astro.url.href} />
    <meta property="og:title" content={`${title} | InsightHub`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl || Astro.url.href} />
    <meta property="twitter:title" content={`${title} | InsightHub`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Canonical URL -->
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Robots -->
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Preconnect to important domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="editorial-bg editorial-ink min-h-screen font-serif selection:bg-amber-200"
  >
    <nav
      data-nav
      class="fixed inset-x-0 top-0 z-50 bg-transparent py-6 transition-all duration-500"
    >
      <div class="editorial-wide flex items-center justify-between px-6">
        <div class="flex items-center gap-7">
          <a
            href="/"
            class="flex items-center gap-1 font-sans text-[2rem] font-black leading-none tracking-[-0.03em]"
          >
            INSIGHT<span
              class="text-amber-600 underline decoration-2 underline-offset-4"
              >HUB</span
            >
          </a>
          <div
            class="hidden gap-7 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-500 lg:flex"
          >
            {
              categories.slice(0, 3).map((cat) => (
                <a
                  href={cat.href}
                  class="transition-colors hover:text-amber-600"
                >
                  {cat.label}
                </a>
              ))
            }
          </div>
        </div>

        <div class="flex items-center gap-5">
          <button
            type="button"
            class="rounded-full p-2 transition-colors hover:bg-gray-100"
            aria-label="Search"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
          <button
            data-newsletter-open
            type="button"
            class="editorial-ink-bg hidden rounded-full px-7 py-3 font-sans text-[11px] font-bold tracking-[0.08em] text-white transition-all hover:bg-amber-600 md:block"
          >
            SUBSCRIBE
          </button>
          <button
            data-mobile-toggle
            type="button"
            class="lg:hidden"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg
              data-menu-icon
              class="h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <svg
              data-close-icon
              class="hidden h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <div
        id="mobile-nav"
        data-mobile-menu
        class="editorial-wide hidden px-6 pb-4 pt-4 lg:hidden"
      >
        <div
          class="rounded-2xl border border-gray-200 bg-white/95 p-4 shadow-sm backdrop-blur"
        >
          <div
            class="flex flex-col gap-4 font-sans text-xs font-semibold uppercase tracking-[0.2em] text-gray-700"
          >
            {
              categories.map((cat) => (
                <a
                  href={cat.href}
                  class="transition-colors hover:text-amber-600"
                >
                  {cat.label}
                </a>
              ))
            }
            <a href="/about" class="transition-colors hover:text-amber-600"
              >About</a
            >
            <a href="/contact" class="transition-colors hover:text-amber-600"
              >Contact</a
            >
          </div>
        </div>
      </div>
    </nav>

    <main>
      <section class="px-6 pb-14 pt-28 lg:pb-16 lg:pt-32">
        <div class="editorial-wide px-0">
          <div class="mb-14 flex flex-col items-end gap-10 lg:mb-16 lg:flex-row lg:gap-12">
            <div class="lg:w-2/3">
              <span
                class="mb-6 inline-block rounded-sm bg-amber-100 px-3 py-1 font-sans text-[11px] font-bold uppercase tracking-[0.24em] text-amber-800"
              >
                Editorial Choice
              </span>
              <h1
                class="mb-6 text-[clamp(3.5rem,5.8vw,5.2rem)] font-bold italic leading-[0.94] tracking-[-0.02em] lg:mb-8"
              >
                Refining the art of <br />
                <span class="not-italic font-black">Modern Living.</span>
              </h1>
              <p class="max-w-[43rem] text-[1.45rem] leading-[1.55] text-gray-400 lg:text-[1.75rem]">
                Expert-led perspectives on the intersection of personal growth,
                financial mastery, and sophisticated lifestyle design.
              </p>
            </div>
            <div class="flex lg:w-1/3 lg:justify-end">
              <div
                class="flex items-center gap-4 font-sans text-[13px] uppercase tracking-[0.08em] text-gray-400"
              >
                <div class="h-[1px] w-12 bg-gray-300"></div>
                <span>ESTABLISHED 2024</span>
              </div>
            </div>
          </div>

          {
            heroPost ? (
              <div class="group relative mx-auto max-w-fit overflow-hidden rounded-2xl bg-white shadow-2xl transition-transform duration-700 hover:-translate-y-2">
                <div class="flex flex-col lg:flex-row lg:items-start">
                  <div class="overflow-hidden lg:w-3/5">
                    <img
                      src={heroPost.image}
                      alt={heroPost.title}
                      class="h-[300px] w-full object-cover transition-transform duration-1000 group-hover:scale-105 md:h-[420px] lg:h-[600px]"
                    />
                  </div>
                  <div class="flex flex-col justify-center p-8 lg:w-2/5 lg:p-12">
                    <div
                      class="mb-4 flex items-center gap-2 font-sans text-[12px] font-bold uppercase tracking-[0.15em] text-amber-600"
                    >
                      <svg
                        class="h-[14px] w-[14px]"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                      >
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                        <polyline points="17 6 23 6 23 12"></polyline>
                      </svg>
                      {heroPost.category}
                    </div>
                    <h2 class="mb-5 text-[clamp(2rem,2.9vw,2.8rem)] font-bold leading-[1.03] tracking-[-0.01em] transition-colors hover:text-amber-600">
                      <a href={heroPost.href}>{heroPost.title}</a>
                    </h2>
                    <p
                      class="mb-8 text-[clamp(1.05rem,1.1vw,1.18rem)] leading-[1.55] text-gray-500"
                    >
                      {heroPost.excerpt}
                    </p>
                    <div
                      class="mt-auto flex items-center justify-between border-t border-gray-100 pt-6"
                    >
                      <div class="flex items-center gap-3">
                        <div
                          class="h-10 w-10 overflow-hidden rounded-full bg-gray-200"
                        >
                          <img
                            src="https://i.pravatar.cc/150?u=1"
                            alt="Author avatar"
                            loading="lazy"
                          />
                        </div>
                        <div>
                          <p class="font-sans text-sm font-bold">{heroPost.author}</p>
                          <p class="font-sans text-xs text-gray-400">
                            Editorial Desk
                          </p>
                        </div>
                      </div>
                      <a
                        href={heroPost.href}
                        class="flex items-center gap-1 font-sans text-[13px] font-bold tracking-[0.16em] transition-transform group-hover:translate-x-2"
                      >
                        READ STORY
                        <svg
                          class="h-4 w-4"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.8"
                        >
                          <line x1="7" y1="17" x2="17" y2="7"></line>
                          <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div class="rounded-2xl border border-gray-200 bg-white/70 p-10 text-center shadow-sm">
                <p class="font-sans text-[11px] font-bold uppercase tracking-[0.22em] text-gray-400">
                  No published editorial features yet
                </p>
              </div>
            )
          }
        </div>
      </section>

      <section class="bg-white py-24">
        <div class="editorial-stage px-6">
          <div class="mb-16 flex items-end justify-between gap-6">
            <div>
              <h3
                class="mb-4 font-sans text-[12px] font-black uppercase tracking-[0.3em] text-gray-400"
              >
                LATEST INSIGHTS
              </h3>
              <h2
                class="text-[clamp(2.35rem,3.2vw,3.6rem)] font-bold leading-[1.02]"
              >
                Curated Reading
              </h2>
            </div>
            <div class="flex items-center gap-4">
              <a
                href="/stats"
                class="border-b-2 border-black pb-1 font-sans text-[13px] font-bold tracking-[0.08em] transition-all hover:border-amber-600 hover:text-amber-600"
              >
                VIEW ARCHIVE
              </a>
              <div class:list={["hidden items-center gap-2 md:flex", featuredPosts.length <= 1 && "md:hidden"]}>
                <button
                  type="button"
                  data-carousel-prev
                  class="flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-black transition-all hover:border-amber-600 hover:text-amber-600"
                  aria-label="Previous articles"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                  </svg>
                </button>
                <button
                  type="button"
                  data-carousel-next
                  class="flex h-11 w-11 items-center justify-center rounded-full border border-black/10 bg-white text-black transition-all hover:border-amber-600 hover:text-amber-600"
                  aria-label="Next articles"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <div
            data-carousel
            class="relative overflow-hidden"
            aria-label="Curated Reading articles"
          >
            {
              featuredPosts.length > 0 ? (
                <>
                  <div
                    data-carousel-slides
                    class="grid gap-12 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
                  >
                  {
                    featuredPosts.slice(0, 4).map((post) => (
                      <article class="group cursor-pointer">
                        <a href={post.href} class="block">
                          <div class="relative mb-6 aspect-square overflow-hidden rounded-xl">
                            <img
                              src={post.image}
                              alt={post.title}
                              loading="lazy"
                              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                            />
                            <div class="absolute left-4 top-4">
                              <span class="rounded bg-white/90 px-3 py-1 font-sans text-[11px] font-bold uppercase tracking-[0.14em] backdrop-blur-sm">
                                {post.category}
                              </span>
                            </div>
                            <button
                              type="button"
                              class="absolute bottom-4 right-4 rounded-full bg-white/20 p-3 text-white opacity-0 backdrop-blur-md transition-opacity group-hover:opacity-100"
                              aria-label="Bookmark article"
                            >
                              <svg
                                class="h-[18px] w-[18px]"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                              >
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                              </svg>
                            </button>
                          </div>
                          <div class="mb-3 flex items-center gap-4 font-sans text-[11px] uppercase tracking-[0.14em] text-gray-400">
                            <span class="flex items-center gap-1">
                              <svg
                                class="h-3 w-3"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                              >
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                              </svg>
                              {post.readTime}
                            </span>
                            <span>&bull;</span>
                            <span>{post.date}</span>
                          </div>
                          <h4 class="mb-3 text-[clamp(1.1rem,2.6vw,2rem)] font-bold leading-[1.08] transition-colors group-hover:text-amber-700">
                            {post.title}
                          </h4>
                          <p class="line-clamp-3 text-[clamp(1.06rem,1.05vw,1.25rem)] leading-[1.55] text-gray-500">
                            {post.excerpt}
                          </p>
                        </a>
                      </article>
                    ))
                  }
                  </div>
                  <script
                    type="application/json"
                    data-carousel-data
                    set:html={JSON.stringify(featuredPosts).replace(/</g, "\\u003c")}
                  >
                  </script>
                </>
              ) : (
                <div class="rounded-2xl border border-gray-200 bg-gray-50/70 p-10 text-center">
                  <p class="font-sans text-[11px] font-bold uppercase tracking-[0.22em] text-gray-400">
                    No published insights available yet
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </section>

      <section
        class="editorial-ink-bg relative overflow-hidden py-24 text-white"
      >
        <div
          class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-amber-600/10 to-transparent"
        >
        </div>
        <div class="editorial-stage relative z-10 px-6 text-center">
          <svg
            class="mx-auto mb-8 text-amber-500"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <path d="M4 4h16v16H4z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          <h2 class="mb-6 text-4xl font-bold md:text-5xl">
            The Sunday Briefing
          </h2>
          <p class="mx-auto mb-10 max-w-2xl text-lg italic text-gray-400">
            "A weekly curation of high-impact ideas for those who value time and
            intellect. Join 50,000+ subscribers who receive our exclusive
            analysis."
          </p>
          <div class="mx-auto flex max-w-md flex-col gap-4 sm:flex-row">
            <input
              type="email"
              placeholder="Your email address"
              class="flex-1 rounded-full border border-white/10 bg-white/5 px-6 py-4 font-sans focus:border-amber-500 focus:outline-none transition-colors"
            />
            <button
              data-newsletter-open
              type="button"
              class="whitespace-nowrap rounded-full bg-white px-8 py-4 font-sans font-bold text-black transition-all hover:bg-amber-500 hover:text-white"
            >
              JOIN NOW
            </button>
          </div>
          <p
            class="mt-6 font-sans text-xs uppercase tracking-widest text-gray-500"
          >
            No spam. No noise. Just insight.
          </p>
        </div>
      </section>
    </main>

    <div
      data-newsletter-modal
      class="fixed inset-0 z-[60] hidden"
      role="dialog"
      aria-modal="true"
      aria-labelledby="newsletter-title"
    >
      <button
        data-newsletter-close
        type="button"
        class="absolute inset-0 h-full w-full bg-black/55 backdrop-blur-[2px]"
        aria-label="Close newsletter modal"
      ></button>
      <div class="relative mx-auto mt-[12vh] w-[calc(100%-2rem)] max-w-xl rounded-2xl bg-white p-8 shadow-2xl">
        <button
          data-newsletter-close
          type="button"
          class="absolute right-4 top-4 rounded-full p-2 text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-800"
          aria-label="Close"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <p class="mb-3 font-sans text-[11px] font-bold uppercase tracking-[0.26em] text-amber-600">
          Newsletter
        </p>
        <h3 id="newsletter-title" class="mb-3 text-4xl font-bold leading-[1.05]">
          Get the latest articles first.
        </h3>
        <p class="mb-8 text-lg leading-relaxed text-gray-500">
          Receive curated weekly insights from finance, home improvement, and
          health directly in your inbox.
        </p>
        <form data-newsletter-form class="flex flex-col gap-4 sm:flex-row">
          <input
            data-newsletter-email
            type="email"
            required
            placeholder="Your email address"
            class="flex-1 rounded-full border border-gray-200 px-6 py-4 font-sans focus:border-amber-500 focus:outline-none"
          />
          <button
            type="submit"
            class="whitespace-nowrap rounded-full bg-black px-8 py-4 font-sans text-sm font-bold tracking-[0.08em] text-white transition-colors hover:bg-amber-600"
          >
            SUBSCRIBE
          </button>
        </form>
        <p
          data-newsletter-success
          class="mt-4 hidden font-sans text-xs font-semibold uppercase tracking-[0.14em] text-emerald-600"
        >
          Thanks. You are subscribed.
        </p>
      </div>
    </div>

    <footer class="editorial-dark border-t border-white/5 text-white">
      <div class="editorial-wide px-6 py-20">
        <div
          class="mb-20 grid grid-cols-1 gap-16 md:grid-cols-2 lg:grid-cols-4"
        >
          <div class="lg:col-span-1">
            <a
              href="/"
              class="mb-8 block font-sans text-2xl font-black tracking-tighter"
            >
              INSIGHT<span class="text-amber-500">HUB</span>
            </a>
            <p class="text-sm italic leading-relaxed text-gray-500">
              Elevating the standard of online editorial. We believe in depth,
              nuance, and the pursuit of excellence in every facet of life.
            </p>
            <div class="mt-8 flex gap-4">
              <a
                href="https://x.com"
                class="rounded-full border border-white/10 p-2 transition-all hover:bg-white hover:text-black"
                aria-label="Twitter"
              >
                <svg
                  class="h-[18px] w-[18px]"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    d="M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 16.5 3a4.5 4.5 0 0 0-4.5 4.5c0 .35.04.7.12 1.03A12.94 12.94 0 0 1 3 4s-4 9 5 13a13.2 13.2 0 0 1-7 2c9 5 20 0 20-11.5 0-.18 0-.37-.01-.55A7.72 7.72 0 0 0 23 3z"
                  ></path>
                </svg>
              </a>
              <a
                href="https://instagram.com"
                class="rounded-full border border-white/10 p-2 transition-all hover:bg-white hover:text-black"
                aria-label="Instagram"
              >
                <svg
                  class="h-[18px] w-[18px]"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                  ></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              </a>
