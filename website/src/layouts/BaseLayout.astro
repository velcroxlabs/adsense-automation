---
import type { Props } from 'astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Your source for quality content on personal finance, home improvement, and health & wellness.',
  canonicalUrl,
  ogImage = '/default-og.jpg',
  noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title><%= title %> | InsightHub</title>
    <meta name="title" content={`${title} | InsightHub`} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl || Astro.url.href} />
    <meta property="og:title" content={`${title} | AdSense Automation`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl || Astro.url.href} />
    <meta property="twitter:title" content={`${title} | AdSense Automation`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Canonical URL -->
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    
    <!-- Robots -->
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Preconnect to important domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-100">
      <nav class="container mx-auto px-4 py-5">
        <div class="flex justify-between items-center">
          <a href="/" class="text-2xl font-bold text-gray-900">
            Insight<span class="text-teal-600">Hub</span>
          </a>
          <div class="hidden md:flex space-x-10">
            <a href="/category/personal-finance" class="text-gray-700 hover:text-teal-600 font-medium transition-colors">Personal Finance</a>
            <a href="/category/home-improvement" class="text-gray-700 hover:text-teal-600 font-medium transition-colors">Home Improvement</a>
            <a href="/category/health-wellness" class="text-gray-700 hover:text-teal-600 font-medium transition-colors">Health & Wellness</a>
            <a href="/about" class="text-gray-700 hover:text-teal-600 font-medium transition-colors">About</a>
            <a href="/contact" class="text-gray-700 hover:text-teal-600 font-medium transition-colors">Contact</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-16">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
          <div class="md:col-span-2">
            <h3 class="text-2xl font-bold mb-6">Insight<span class="text-teal-400">Hub</span></h3>
            <p class="text-gray-300 max-w-md text-lg">
              Practical wisdom and expert insights to help you master personal finance, home improvement, and wellness.
            </p>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-6">Quick Links</h4>
            <ul class="space-y-3">
              <li><a href="/about" class="text-gray-300 hover:text-white transition-colors">About Us</a></li>
              <li><a href="/privacy" class="text-gray-300 hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="text-gray-300 hover:text-white transition-colors">Terms of Service</a></li>
              <li><a href="/contact" class="text-gray-300 hover:text-white transition-colors">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-6">Categories</h4>
            <ul class="space-y-3">
              <li><a href="/category/personal-finance" class="text-gray-300 hover:text-white transition-colors">Personal Finance</a></li>
              <li><a href="/category/home-improvement" class="text-gray-300 hover:text-white transition-colors">Home Improvement</a></li>
              <li><a href="/category/health-wellness" class="text-gray-300 hover:text-white transition-colors">Health & Wellness</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-12 pt-8 text-center text-gray-400">
          <p>&copy; {new Date().getFullYear()} InsightHub. Practical wisdom for modern living.</p>
          <p class="mt-2 text-sm">All content is expertly researched and regularly updated.</p>
        </div>
      </div>
    </footer>

    <!-- AdSense Script (to be added after approval) -->
    {/* <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXX" crossorigin="anonymous"></script> */}
  </body>
</html>