---
import type { Props } from 'astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Your source for quality content on personal finance, home improvement, and health & wellness.',
  canonicalUrl,
  ogImage = '/default-og.jpg',
  noindex = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title><%= title %> | AdSense Automation</title>
    <meta name="title" content={`${title} | AdSense Automation`} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl || Astro.url.href} />
    <meta property="og:title" content={`${title} | AdSense Automation`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl || Astro.url.href} />
    <meta property="twitter:title" content={`${title} | AdSense Automation`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Canonical URL -->
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    
    <!-- Robots -->
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Preconnect to important domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans min-h-screen">
    <!-- Header -->
    <header class="bg-white shadow-sm">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex justify-between items-center">
          <a href="/" class="text-2xl font-bold text-blue-600">
            AdSense Auto
          </a>
          <div class="hidden md:flex space-x-8">
            <a href="/personal-finance" class="text-gray-700 hover:text-blue-600">Personal Finance</a>
            <a href="/home-improvement" class="text-gray-700 hover:text-blue-600">Home Improvement</a>
            <a href="/health-wellness" class="text-gray-700 hover:text-blue-600">Health & Wellness</a>
            <a href="/stats" class="text-gray-700 hover:text-blue-600">Stats</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white mt-12">
      <div class="container mx-auto px-4 py-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-xl font-bold mb-4">AdSense Auto</h3>
            <p class="text-gray-300">
              Automated content generation for niche websites. Quality articles on personal finance, home improvement, and health & wellness.
            </p>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2">
              <li><a href="/about" class="text-gray-300 hover:text-white">About Us</a></li>
              <li><a href="/privacy" class="text-gray-300 hover:text-white">Privacy Policy</a></li>
              <li><a href="/terms" class="text-gray-300 hover:text-white">Terms of Service</a></li>
              <li><a href="/contact" class="text-gray-300 hover:text-white">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4">Categories</h4>
            <ul class="space-y-2">
              <li><a href="/personal-finance" class="text-gray-300 hover:text-white">Personal Finance</a></li>
              <li><a href="/home-improvement" class="text-gray-300 hover:text-white">Home Improvement</a></li>
              <li><a href="/health-wellness" class="text-gray-300 hover:text-white">Health & Wellness</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-gray-400">
          <p>&copy; {new Date().getFullYear()} AdSense Automation. All rights reserved.</p>
          <p class="mt-2 text-sm">This website uses automated content generation.</p>
        </div>
      </div>
    </footer>

    <!-- AdSense Script (to be added after approval) -->
    {/* <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXX" crossorigin="anonymous"></script> */}
  </body>
</html>