    <!-- AdSense Script (to be added after approval) -->
    {
      /* <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXX" crossorigin="anonymous"></script> */
    }
    <script is:inline>
      (() => {
        const nav = document.querySelector("[data-nav]");
        const toggle = document.querySelector("[data-mobile-toggle]");
        const menu = document.querySelector("[data-mobile-menu]");
        const menuIcon = toggle?.querySelector("[data-menu-icon]");
        const closeIcon = toggle?.querySelector("[data-close-icon]");
        const newsletterModal = document.querySelector("[data-newsletter-modal]");
        const newsletterOpenButtons = document.querySelectorAll("[data-newsletter-open]");
        const newsletterCloseButtons = document.querySelectorAll("[data-newsletter-close]");
        const newsletterForm = document.querySelector("[data-newsletter-form]");
        const newsletterEmail = document.querySelector("[data-newsletter-email]");
        const newsletterSuccess = document.querySelector("[data-newsletter-success]");
        const carousel = document.querySelector("[data-carousel]");
        const carouselSlides = document.querySelector("[data-carousel-slides]");
        const carouselData = document.querySelector("[data-carousel-data]");
        const carouselPrev = document.querySelector("[data-carousel-prev]");
        const carouselNext = document.querySelector("[data-carousel-next]");

        if (nav) {
          const updateNav = () => {
            const scrolled = window.scrollY > 50;
            nav.classList.toggle("bg-white/80", scrolled);
            nav.classList.toggle("backdrop-blur-md", scrolled);
            nav.classList.toggle("py-3", scrolled);
            nav.classList.toggle("shadow-sm", scrolled);
            nav.classList.toggle("bg-transparent", !scrolled);
            nav.classList.toggle("py-6", !scrolled);
          };
          updateNav();
          window.addEventListener("scroll", updateNav, { passive: true });
        }

        if (toggle && menu && menuIcon && closeIcon) {
          const setState = (open) => {
            menu.classList.toggle("hidden", !open);
            menuIcon.classList.toggle("hidden", open);
            closeIcon.classList.toggle("hidden", !open);
            toggle.setAttribute("aria-expanded", open ? "true" : "false");
          };
          setState(false);
          toggle.addEventListener("click", () => {
            const open = toggle.getAttribute("aria-expanded") !== "true";
            setState(open);
          });
        }

        if (newsletterModal) {
          const setNewsletterState = (open) => {
            newsletterModal.classList.toggle("hidden", !open);
            document.body.classList.toggle("overflow-hidden", open);
            if (open && newsletterEmail instanceof HTMLInputElement) {
              newsletterEmail.focus();
            }
          };

          newsletterOpenButtons.forEach((button) => {
            button.addEventListener("click", () => setNewsletterState(true));
          });

          newsletterCloseButtons.forEach((button) => {
            button.addEventListener("click", () => setNewsletterState(false));
          });

          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && !newsletterModal.classList.contains("hidden")) {
              setNewsletterState(false);
            }
          });

          if (newsletterForm instanceof HTMLFormElement) {
            newsletterForm.addEventListener("submit", (event) => {
              event.preventDefault();
              if (newsletterSuccess) {
                newsletterSuccess.classList.remove("hidden");
              }
              newsletterForm.reset();
            });
          }
        }

        if (
          carousel instanceof HTMLElement &&
          carouselSlides instanceof HTMLElement &&
          carouselData instanceof HTMLScriptElement
        ) {
          const posts = JSON.parse(carouselData.textContent ?? "[]");
          let index = 0;
          let autoAdvanceId;

          if (!Array.isArray(posts) || posts.length === 0) {
            return;
          }

          const getVisibleCount = () => {
            if (window.innerWidth >= 1280) return 4;
            if (window.innerWidth >= 1024) return 3;
            if (window.innerWidth >= 768) return 2;
            return 1;
          };

          const escapeHtml = (value) =>
            String(value)
              .replaceAll("&", "&amp;")
              .replaceAll("<", "&lt;")
              .replaceAll(">", "&gt;")
              .replaceAll('"', "&quot;")
              .replaceAll("'", "&#39;");

          const renderCard = (post) => `
            <article class="group cursor-pointer">
              <a href="${escapeHtml(post.href)}" class="block">
                <div class="relative mb-6 aspect-square overflow-hidden rounded-xl">
                  <img
                    src="${escapeHtml(post.image)}"
                    alt="${escapeHtml(post.title)}"
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                  />
                  <div class="absolute left-4 top-4">
                    <span class="rounded bg-white/90 px-3 py-1 font-sans text-[11px] font-bold uppercase tracking-[0.14em] backdrop-blur-sm">
                      ${escapeHtml(post.category)}
                    </span>
                  </div>
                  <button
                    type="button"
                    class="absolute bottom-4 right-4 rounded-full bg-white/20 p-3 text-white opacity-0 backdrop-blur-md transition-opacity group-hover:opacity-100"
                    aria-label="Bookmark article"
                  >
                    <svg
                      class="h-[18px] w-[18px]"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
                    </svg>
                  </button>
                </div>
                <div class="mb-3 flex items-center gap-4 font-sans text-[11px] uppercase tracking-[0.14em] text-gray-400">
                  <span class="flex items-center gap-1">
                    <svg
                      class="h-3 w-3"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    ${escapeHtml(post.readTime)}
                  </span>
                  <span>&bull;</span>
                  <span>${escapeHtml(post.date)}</span>
                </div>
                <h4 class="mb-3 text-[clamp(1.1rem,2.6vw,2rem)] font-bold leading-[1.08] transition-colors group-hover:text-amber-700">
                  ${escapeHtml(post.title)}
                </h4>
                <p class="line-clamp-3 text-[clamp(1.06rem,1.05vw,1.25rem)] leading-[1.55] text-gray-500">
                  ${escapeHtml(post.excerpt)}
                </p>
              </a>
            </article>
          `;

          const render = () => {
            const visibleCount = Math.min(getVisibleCount(), posts.length);
            const visiblePosts = Array.from({ length: visibleCount }, (_, offset) =>
              posts[(index + offset) % posts.length]
            );

            carouselSlides.innerHTML = visiblePosts.map(renderCard).join("");
          };

          const move = (direction) => {
            index = (index + direction + posts.length) % posts.length;
            render();
          };

          const startAutoAdvance = () => {
            stopAutoAdvance();
            if (posts.length > getVisibleCount()) {
              autoAdvanceId = window.setInterval(() => move(1), 4200);
            }
          };

          const stopAutoAdvance = () => {
            if (autoAdvanceId) {
              window.clearInterval(autoAdvanceId);
            }
          };

          render();
          startAutoAdvance();

          carousel.addEventListener("mouseenter", stopAutoAdvance);
          carousel.addEventListener("mouseleave", startAutoAdvance);
          carousel.addEventListener("focusin", stopAutoAdvance);
          carousel.addEventListener("focusout", startAutoAdvance);
          carouselPrev?.addEventListener("click", () => {
            stopAutoAdvance();
            move(-1);
            startAutoAdvance();
          });
          carouselNext?.addEventListener("click", () => {
            stopAutoAdvance();
            move(1);
            startAutoAdvance();
          });

          window.addEventListener("resize", render);
        }
      })();
    </script>
  </body>
</html>
