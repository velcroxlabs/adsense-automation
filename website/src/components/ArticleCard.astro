---
import type { ArticleWithKeyword } from '../lib/types';

export interface Props {
  article: ArticleWithKeyword;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

// Helper para determinar color de nicho
const getNicheColor = (niche: string) => {
  switch (niche?.toLowerCase()) {
    case 'personal finance':
      return { bg: 'bg-blue-100', text: 'text-blue-700', border: 'border-blue-200' };
    case 'home improvement':
      return { bg: 'bg-green-100', text: 'text-green-700', border: 'border-green-200' };
    case 'health & wellness':
    case 'health':
      return { bg: 'bg-purple-100', text: 'text-purple-700', border: 'border-purple-200' };
    default:
      return { bg: 'bg-gray-100', text: 'text-gray-700', border: 'border-gray-200' };
  }
};

const nicheColors = getNicheColor(article.keywords?.seed_niche || '');
const readTime = article.metadata?.word_count ? Math.ceil(article.metadata.word_count / 200) : 5;
---

<article class={`${featured ? 'card hover:shadow-xl transition-all duration-300' : 'border rounded-lg p-5 hover:shadow-md transition-shadow'} ${nicheColors.border} border-l-4`}>
  <div class="mb-4">
    <span class={`inline-block px-3 py-1 text-sm font-semibold ${nicheColors.text} ${nicheColors.bg} rounded-full`}>
      {article.keywords?.seed_niche || 'General'}
    </span>
  </div>
  
  <h3 class={`${featured ? 'text-2xl' : 'text-xl'} font-bold mb-3`}>
    <a 
      href={`/article/${article.slug}`} 
      class="hover:text-blue-600 transition-colors"
    >
      {article.title}
    </a>
  </h3>
  
  <p class="text-gray-600 mb-4 line-clamp-3">
    {article.excerpt || 'Read this informative article...'}
  </p>
  
  <div class="flex items-center justify-between text-sm text-gray-500">
    <div class="flex items-center space-x-4">
      <span>{readTime} min read</span>
      {article.published_at && (
        <>
          <span>•</span>
          <time datetime={new Date(article.published_at).toISOString()}>
            {new Date(article.published_at).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric'
            })}
          </time>
        </>
      )}
    </div>
    
    {article.metadata?.word_count && (
      <span class="text-gray-400">
        {article.metadata.word_count.toLocaleString()} words
      </span>
    )}
  </div>
  
  {featured && article.keywords?.keyword && (
    <div class="mt-4 pt-4 border-t border-gray-100">
      <p class="text-sm text-gray-500">
        Target keyword: <span class="font-medium text-gray-700">{article.keywords.keyword}</span>
      </p>
    </div>
  )}
</article>