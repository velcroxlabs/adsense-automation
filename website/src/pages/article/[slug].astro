---
import ContentLayout from "../../layouts/ContentLayout.astro";
import {
  getPublishedArticleBySlug,
  getPublishedArticleSlugs,
} from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";

type NicheMeta = {
  label: string;
  accentBg: string;
  accentText: string;
  accentBorder: string;
  categorySlug: string;
};

export async function getStaticPaths() {
  const slugs = await getPublishedArticleSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const article = slug ? await getPublishedArticleBySlug(slug) : null;

if (!article) {
  return Astro.redirect("/404");
}

const getNicheMeta = (niche: string): NicheMeta => {
  const normalized = niche.toLowerCase();

  if (normalized.includes("finance")) {
    return {
      label: "Wealth Management",
      accentBg: "bg-amber-600",
      accentText: "text-amber-600",
      accentBorder: "border-amber-600",
      categorySlug: "personal-finance",
    };
  }

  if (normalized.includes("home")) {
    return {
      label: "Interior Design",
      accentBg: "bg-stone-600",
      accentText: "text-stone-600",
      accentBorder: "border-stone-600",
      categorySlug: "home-improvement",
    };
  }

  if (normalized.includes("health") || normalized.includes("wellness")) {
    return {
      label: "Longevity Science",
      accentBg: "bg-emerald-700",
      accentText: "text-emerald-700",
      accentBorder: "border-emerald-700",
      categorySlug: "health-wellness",
    };
  }

  return {
    label: "Perspective",
    accentBg: "bg-gray-500",
    accentText: "text-gray-500",
    accentBorder: "border-gray-500",
    categorySlug: "personal-finance",
  };
};

const meta = getNicheMeta(article.niche);
const publishDate = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    })
  : "Recent Edition";

const tags =
  article.tags.length > 0
    ? article.tags
    : [meta.label, article.niche, "Insights"];
const articleHtml = await renderMarkdown(article.content);
---

<ContentLayout
  title={article.title}
  description={article.excerpt}
  canonicalUrl={`/article/${article.slug}`}
>
  <div
    class="editorial-ink min-h-screen bg-white font-serif selection:bg-amber-100"
  >
    <div class="fixed left-0 top-0 z-50 h-1 w-full bg-gray-100">
      <div
        id="reading-progress"
        class={`h-full ${meta.accentBg} transition-all duration-150`}
        style="width: 0%;"
      >
      </div>
    </div>

    <nav
      class="sticky top-0 z-40 border-b border-gray-100 bg-white/90 px-6 py-6 backdrop-blur-md"
    >
      <div class="editorial-wide flex items-center justify-between">
        <a
          href={`/category/${meta.categorySlug}`}
          class="flex items-center gap-2 font-sans text-[11px] font-black uppercase tracking-[0.2em] transition-colors hover:text-amber-600"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to Library
        </a>
        <div
          class="hidden max-w-[55vw] truncate font-sans text-[11px] font-black uppercase tracking-[0.24em] text-gray-400 md:block"
        >
          {meta.label}
          <span class="mx-2 inline-block align-middle text-[11px]"
            >&rsaquo;</span
          >
          {article.title}
        </div>
        <div class="flex gap-4">
          <button
            type="button"
            class="rounded-full p-2 transition-colors hover:bg-gray-50"
            aria-label="Bookmark article"
          >
            <svg
              class="h-[18px] w-[18px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
              ></path>
            </svg>
          </button>
          <button
            type="button"
            class="rounded-full p-2 transition-colors hover:bg-gray-50"
            aria-label="Share article"
          >
            <svg
              class="h-[18px] w-[18px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="editorial-wide px-6 py-12 lg:px-8 lg:py-24">
      <header class="mx-auto mb-16 max-w-4xl text-center lg:mb-24">
        <div
          class="mb-8 inline-block rounded-full border border-gray-200 px-4 py-1.5"
        >
          <span
            class="font-sans text-[10px] font-black uppercase tracking-[0.3em] text-gray-500"
          >
            {meta.label}
          </span>
        </div>
        <h1
          class="mb-10 text-4xl font-bold italic leading-[1.1] tracking-tight md:text-6xl lg:text-7xl"
        >
          {article.title}
        </h1>
        <p
          class="mb-12 text-xl font-light leading-relaxed text-gray-500 md:text-2xl"
        >
          {article.excerpt}
        </p>
        <div
          class="flex flex-col items-center justify-center gap-6 border-b border-t border-gray-100 py-8 font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 md:flex-row"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-500"
            >
              <svg
                class="h-[18px] w-[18px]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path d="M20 21a8 8 0 1 0-16 0"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <span class="text-black">{article.author}</span>
          </div>
          <div class="hidden h-4 w-[1px] bg-gray-200 md:block"></div>
          <div class="flex items-center gap-2">
            <svg
              class="h-[14px] w-[14px]"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            {article.readTimeLabel.toUpperCase()}
          </div>
          <div class="hidden h-4 w-[1px] bg-gray-200 md:block"></div>
          <div>{publishDate}</div>
        </div>
      </header>

      <div class="mb-20 w-full lg:mb-32">
        <div
          class="aspect-[16/9] overflow-hidden rounded-sm bg-gray-100 xl:aspect-[21/9]"
        >
          <img
            src={article.featuredImage}
            class="h-full w-full object-cover"
            alt="Article hero"
            loading="eager"
            referrerpolicy="no-referrer"
          />
        </div>
        <p
          class="mt-4 text-center font-sans text-[10px] italic uppercase tracking-widest text-gray-400"
        >
          Illustration of strategic frameworks within the {
            meta.label.toLowerCase()
          } landscape.
        </p>
      </div>

      <div class="relative grid grid-cols-1 gap-12 lg:grid-cols-9 lg:gap-8">
        <aside class="sticky top-32 hidden h-fit lg:col-span-2 lg:block">
          <div
            class="flex flex-col gap-8 border-r border-gray-50 pr-8 text-gray-300"
          >
            <button
              type="button"
              class="flex flex-col items-center gap-1 transition-colors hover:text-amber-600"
              aria-label="Like article"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M14 9V5a3 3 0 0 0-3-3l-1 4-3 5v10h11.28a2 2 0 0 0 2-1.73l1-7A2 2 0 0 0 19.3 10H14z"
                ></path>
                <path d="M7 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h3"></path>
              </svg>
              <span class="font-sans text-[9px] font-bold">1.2K</span>
            </button>
            <button
              type="button"
              class="flex flex-col items-center gap-1 transition-colors hover:text-amber-600"
              aria-label="Comments"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
              <span class="font-sans text-[9px] font-bold">48</span>
            </button>
            <div class="my-2 h-[1px] w-full bg-gray-100"></div>
            <button
              type="button"
              class="flex flex-col items-center gap-1 transition-colors hover:text-blue-400"
              aria-label="Share on Twitter"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M23 3a10.9 10.9 0 0 1-3.14 1.53A4.48 4.48 0 0 0 16.5 3a4.5 4.5 0 0 0-4.5 4.5c0 .35.04.7.12 1.03A12.94 12.94 0 0 1 3 4s-4 9 5 13a13.2 13.2 0 0 1-7 2c9 5 20 0 20-11.5 0-.18 0-.37-.01-.55A7.72 7.72 0 0 0 23 3z"
                ></path>
              </svg>
            </button>
            <button
              type="button"
              class="flex flex-col items-center gap-1 transition-colors hover:text-blue-700"
              aria-label="Share on LinkedIn"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </button>
            <button
              type="button"
              class="flex flex-col items-center gap-1 transition-colors hover:text-black"
              aria-label="Copy link"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07L11.3 5.64"
                ></path>
                <path
                  d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l2.17-2.17"
                ></path>
              </svg>
            </button>
          </div>
        </aside>

        <article class="min-w-0 w-full max-w-none lg:col-span-8 lg:col-start-4">
          <div
            class={`prose prose-stone max-w-none text-lg leading-[1.8] text-gray-700 md:text-2xl font-serif [&_p:first-of-type::first-letter]:float-left [&_p:first-of-type::first-letter]:pr-3 [&_p:first-of-type::first-letter]:pt-2 [&_p:first-of-type::first-letter]:text-7xl [&_p:first-of-type::first-letter]:font-bold [&_p:first-of-type::first-letter]:leading-none [&_p:first-of-type::first-letter]:text-amber-600 [&_h1]:text-5xl [&_h1]:font-bold [&_h1]:italic [&_h1]:tracking-tight [&_h1]:text-black [&_h2]:mt-16 [&_h2]:text-4xl [&_h2]:font-bold [&_h2]:italic [&_h2]:tracking-tight [&_h2]:text-black [&_h3]:mt-12 [&_h3]:text-2xl [&_h3]:font-bold [&_h3]:text-black [&_blockquote]:my-12 [&_blockquote]:border-l-[6px] [&_blockquote]:py-4 [&_blockquote]:pl-10 [&_blockquote]:text-3xl [&_blockquote]:font-bold [&_blockquote]:italic [&_blockquote]:text-black [&_blockquote]:${meta.accentBorder} [&_blockquote_p]:leading-tight [&_blockquote_cite]:mt-4 [&_blockquote_cite]:block [&_blockquote_cite]:font-sans [&_blockquote_cite]:text-[11px] [&_blockquote_cite]:not-italic [&_blockquote_cite]:uppercase [&_blockquote_cite]:tracking-[0.2em] [&_blockquote_cite]:text-gray-400 [&_ol]:list-none [&_ol]:pl-0 [&_ol_li]:relative [&_ol_li]:mb-6 [&_ol_li]:pl-16 [&_ol_li]:font-bold [&_ol_li]:text-gray-800 [&_ol_li]:before:absolute [&_ol_li]:before:left-0 [&_ol_li]:before:top-0 [&_ol_li]:before:text-xl [&_ol_li]:before:font-black [&_ol_li]:before:content-[counter(step-counter,decimal-leading-zero)] [&_ol_li]:before:counter-increment-[step-counter] [&_ol_li]:before:${meta.accentText} [&_ul]:list-none [&_ul]:pl-0 [&_ul_li]:relative [&_ul_li]:mb-5 [&_ul_li]:pl-10 [&_ul_li]:text-gray-800 [&_ul_li]:before:absolute [&_ul_li]:before:left-0 [&_ul_li]:before:top-[0.55em] [&_ul_li]:before:h-2 [&_ul_li]:before:w-2 [&_ul_li]:before:rounded-full [&_ul_li]:before:bg-amber-600 [&_li]:my-2 [&_a]:font-semibold [&_a]:text-amber-700 [&_a]:underline-offset-4 [&_a:hover]:underline`}
            style="counter-reset: step-counter;"
            set:html={articleHtml}
          />
          <div
            class="mt-20 flex flex-wrap gap-4 border-t border-gray-100 pt-10"
          >
            {
              tags.map((tag) => (
                <span class="rounded-sm bg-gray-50 px-4 py-2 font-sans text-[10px] font-bold uppercase tracking-widest text-gray-400">
                  #{tag}
                </span>
              ))
            }
          </div>
        </article>
      </div>
    </main>

    <section class="mt-20 bg-stone-900 px-6 py-24 text-white">
      <div class="mx-auto max-w-4xl text-center">
        <h2 class="mb-8 text-4xl font-bold italic md:text-5xl">
          Subscribe to the Insight Brief.
        </h2>
        <p class="mx-auto mb-12 max-w-2xl text-lg text-stone-400">
          Weekly executive summaries on {meta.label.toLowerCase()} and strategic excellence,
          delivered to your inbox every Sunday morning.
        </p>
        <div class="mx-auto flex max-w-lg flex-col gap-4 md:flex-row">
          <input
            type="email"
            placeholder="Email address"
            class="flex-1 rounded-sm border-none bg-stone-800 px-6 py-4 font-sans text-sm text-white outline-none focus:ring-2 focus:ring-amber-600"
          />
          <button
            type="button"
            class="bg-amber-600 px-8 py-4 font-sans text-[10px] font-black uppercase tracking-widest transition-colors hover:bg-amber-700"
          >
            Join the Circle
          </button>
        </div>
      </div>
    </section>

    <footer class="border-t border-gray-100 py-12 text-center">
      <p
        class="font-sans text-[9px] font-black uppercase tracking-[0.5em] text-gray-300"
      >
        InsightHub Editorial Group &bull; MMXXIV
      </p>
    </footer>
  </div>

  <script is:inline>
    (() => {
      const progress = document.getElementById("reading-progress");

      const updateScrollProgress = () => {
        if (!progress) return;

        const currentScroll = window.scrollY;
        const scrollHeight =
          document.documentElement.scrollHeight - window.innerHeight;

        const percentage = scrollHeight
          ? Math.min(100, (currentScroll / scrollHeight) * 100)
          : 0;

        progress.style.width = `${percentage}%`;
      };

      updateScrollProgress();
      window.addEventListener("scroll", updateScrollProgress, {
        passive: true,
      });
    })();
  </script>
</ContentLayout>
