---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Get the slug from the URL
const { slug } = Astro.params;

// Map slugs to category data
const categories = {
  'personal-finance': {
    name: 'Personal Finance',
    description: 'Expert guides on budgeting, investing, saving strategies, and achieving financial freedom.',
    color: 'teal',
    icon: '💼',
    metaDescription: 'Learn how to manage your money effectively with our comprehensive personal finance guides and investment strategies.'
  },
  'home-improvement': {
    name: 'Home Improvement', 
    description: 'Practical DIY projects, repair guides, renovation tips, and home maintenance advice.',
    color: 'amber',
    icon: '🏠',
    metaDescription: 'Transform your living space with our step-by-step home improvement guides, DIY projects, and renovation tips.'
  },
  'health-wellness': {
    name: 'Health & Wellness',
    description: 'Science-backed advice on fitness, nutrition, mental health, and holistic wellness practices.',
    color: 'emerald',
    icon: '🌱',
    metaDescription: 'Improve your wellbeing with our health and wellness guides covering fitness, nutrition, mental health, and holistic practices.'
  }
};

// Get category data or show 404
const category = categories[slug as keyof typeof categories];

if (!category) {
  return Astro.redirect('/404');
}

// In a real implementation, we would fetch articles from Supabase
// const articles = await articleService.getArticlesByCategory(slug);
// For now, using placeholder data
const placeholderArticles = [
  {
    id: 1,
    title: `How to Master ${category.name}: Essential Guide for Beginners`,
    excerpt: `Learn the fundamental principles and practical steps to excel in ${category.name.toLowerCase()}.`,
    readTime: '8 min read',
    date: 'Recent',
    slug: `master-${slug}-guide`
  },
  {
    id: 2,
    title: `Top 10 ${category.name} Mistakes to Avoid`,
    excerpt: `Common pitfalls and how to steer clear of them for better results.`,
    readTime: '6 min read',
    date: 'Recent',
    slug: `top-10-${slug}-mistakes`
  },
  {
    id: 3,
    title: `Advanced Strategies for ${category.name} Success`,
    excerpt: `Take your skills to the next level with these expert techniques and approaches.`,
    readTime: '10 min read',
    date: 'Recent',
    slug: `advanced-${slug}-strategies`
  },
  {
    id: 4,
    title: `${category.name} Tools and Resources You Need`,
    excerpt: `Essential tools, apps, and resources to help you achieve your goals more effectively.`,
    readTime: '7 min read',
    date: 'Recent',
    slug: `${slug}-tools-resources`
  },
  {
    id: 5,
    title: `Real-World ${category.name} Case Studies`,
    excerpt: `Learn from practical examples and success stories in this field.`,
    readTime: '9 min read',
    date: 'Recent',
    slug: `${slug}-case-studies`
  },
  {
    id: 6,
    title: `Future Trends in ${category.name}`,
    excerpt: `What to expect and how to prepare for upcoming developments in this area.`,
    readTime: '8 min read',
    date: 'Recent',
    slug: `future-trends-${slug}`
  }
];

const colorClasses = {
  teal: {
    bg: 'bg-teal-50',
    text: 'text-teal-700',
    border: 'border-teal-200',
    badge: 'bg-teal-100 text-teal-700',
    button: 'bg-teal-600 hover:bg-teal-700'
  },
  amber: {
    bg: 'bg-amber-50',
    text: 'text-amber-700',
    border: 'border-amber-200',
    badge: 'bg-amber-100 text-amber-700',
    button: 'bg-amber-600 hover:bg-amber-700'
  },
  emerald: {
    bg: 'bg-emerald-50',
    text: 'text-emerald-700',
    border: 'border-emerald-200',
    badge: 'bg-emerald-100 text-emerald-700',
    button: 'bg-emerald-600 hover:bg-emerald-700'
  }
};

const color = colorClasses[category.color as keyof typeof colorClasses];
---

<BaseLayout 
  title={category.name}
  description={category.metaDescription}
  canonicalUrl={`/category/${slug}`}
>
  <!-- Category Header -->
  <div class={`${color.bg} ${color.border} rounded-3xl p-10 mb-12 border-2`}>
    <div class="flex flex-col md:flex-row items-center justify-between">
      <div class="md:w-2/3">
        <div class="inline-flex items-center px-4 py-2 ${color.badge} rounded-full text-sm font-semibold mb-6">
          <div class={`w-2 h-2 rounded-full mr-2 ${category.color === 'teal' ? 'bg-teal-500' : category.color === 'amber' ? 'bg-amber-500' : 'bg-emerald-500'}`}></div>
          Category
        </div>
        <h1 class="text-5xl font-bold text-gray-900 mb-6">
          {category.name}
          <span class="block text-4xl mt-4 opacity-60">{category.icon}</span>
        </h1>
        <p class="text-xl text-gray-700 mb-8 max-w-3xl">
          {category.description}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#articles" class={`px-6 py-3 ${color.button} text-white font-semibold rounded-lg transition-colors`}>
            Browse Articles
          </a>
          <a href="/" class="px-6 py-3 bg-white text-gray-700 font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors">
            Back to Home
          </a>
        </div>
      </div>
      <div class="mt-8 md:mt-0">
        <div class="text-8xl opacity-20">
          {category.icon}
        </div>
      </div>
    </div>
  </div>

  <!-- Articles Grid -->
  <section id="articles" class="mb-20">
    <div class="flex justify-between items-center mb-12">
      <div>
        <h2 class="text-4xl font-bold text-gray-900">Latest {category.name} Guides</h2>
        <p class="text-gray-600 mt-2">Practical articles with actionable advice and expert insights</p>
      </div>
      <div class="text-sm text-gray-500">
        {placeholderArticles.length} articles
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {placeholderArticles.map((article) => (
        <article class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <div class="p-8">
            <div class="mb-6">
              <span class={`inline-block px-3 py-1 text-xs font-semibold ${color.badge} rounded-full`}>
                {category.name}
              </span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4 line-clamp-2">
              <a href={`/article/${article.slug}`} class="hover:text-teal-600 transition-colors">
                {article.title}
              </a>
            </h3>
            <p class="text-gray-600 mb-6 line-clamp-3">
              {article.excerpt}
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <div class="flex items-center space-x-4">
                <span>{article.readTime}</span>
                <span>•</span>
                <span>{article.date}</span>
              </div>
              <a href={`/article/${article.slug}`} class={`${color.text} font-semibold hover:underline`}>
                Read guide →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Load More (Placeholder) -->
    <div class="text-center mt-12">
      <button class="px-8 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg transition-colors">
        Load More Articles
      </button>
      <p class="text-gray-500 text-sm mt-4">
        More content is being added regularly. Check back soon for updates!
      </p>
    </div>
  </section>

  <!-- Category Resources -->
  <section class={`${color.bg} rounded-3xl p-10 mb-12`}>
    <div class="max-w-4xl mx-auto text-center">
      <h3 class="text-3xl font-bold text-gray-900 mb-6">Master {category.name}</h3>
      <p class="text-gray-700 text-lg mb-10 max-w-3xl mx-auto">
        Our comprehensive guides are designed to help you progress from beginner to advanced levels, 
        with practical advice you can implement immediately.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6">
          <div class="text-3xl mb-4">📚</div>
          <h4 class="text-xl font-bold mb-3">Beginner Friendly</h4>
          <p class="text-gray-600">Start with the basics and build your knowledge step by step.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <div class="text-3xl mb-4">🎯</div>
          <h4 class="text-xl font-bold mb-3">Actionable Advice</h4>
          <p class="text-gray-600">Practical steps you can take right away for immediate results.</p>
        </div>
        <div class="bg-white rounded-xl p-6">
          <div class="text-3xl mb-4">🔄</div>
          <h4 class="text-xl font-bold mb-3">Regular Updates</h4>
          <p class="text-gray-600">Content is refreshed to reflect current best practices.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Categories -->
  <section class="mb-20">
    <h3 class="text-3xl font-bold text-gray-900 mb-8 text-center">Explore Related Topics</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {Object.entries(categories)
        .filter(([key]) => key !== slug)
        .map(([key, cat]) => {
          const relatedColor = colorClasses[cat.color as keyof typeof colorClasses];
          return (
            <a 
              href={`/category/${key}`} 
              class={`${relatedColor.bg} ${relatedColor.border} rounded-2xl p-8 border-2 hover:shadow-lg transition-all`}
            >
              <div class="flex items-center">
                <div class="text-4xl mr-6">{cat.icon}</div>
                <div>
                  <h4 class="text-xl font-bold text-gray-900 mb-2">{cat.name}</h4>
                  <p class="text-gray-600 text-sm">{cat.description.substring(0, 80)}...</p>
                  <div class={`mt-4 ${relatedColor.text} font-semibold flex items-center`}>
                    Browse category
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
    </div>
  </section>
</BaseLayout>