---
import ContentLayout from "../../layouts/ContentLayout.astro";
import {
  CATEGORY_SLUGS,
  getPublishedArticlesByCategory,
  type WebsiteArticle,
} from "../../lib/content";

type CategoryKey = "personal-finance" | "home-improvement" | "health-wellness";

interface CategoryData {
  name: string;
  description: string;
  tagline: string;
  icon: string;
  metaDescription: string;
  accentText: string;
  accentLine: string;
  accentUnderline: string;
}

const categories: Record<CategoryKey, CategoryData> = {
  "personal-finance": {
    name: "Wealth Management",
    description:
      "The strategic pursuit of financial independence and sophisticated asset management.",
    tagline: "STRATEGIC WEALTH",
    icon: "\u{1F4BC}",
    metaDescription:
      "Strategic insights on wealth management, financial independence, and advanced asset allocation.",
    accentText: "text-amber-600",
    accentLine: "bg-amber-600",
    accentUnderline: "decoration-amber-500",
  },
  "home-improvement": {
    name: "Interior Design",
    description:
      "Curating spaces that balance architectural integrity with modern minimalist luxury.",
    tagline: "SPACE & DESIGN",
    icon: "\u{1F3E0}",
    metaDescription:
      "Interior design strategy, home curation, and modern methods for practical luxury spaces.",
    accentText: "text-stone-600",
    accentLine: "bg-stone-600",
    accentUnderline: "decoration-stone-500",
  },
  "health-wellness": {
    name: "Longevity & Health",
    description:
      "Science-led practices for metabolic health, cognitive performance, and vitality.",
    tagline: "VITALITY SCIENCE",
    icon: "\u{1F331}",
    metaDescription:
      "Evidence-based guides for longevity, metabolic health, performance, and long-term vitality.",
    accentText: "text-emerald-700",
    accentLine: "bg-emerald-700",
    accentUnderline: "decoration-emerald-500",
  },
};

export async function getStaticPaths() {
  const slugs = CATEGORY_SLUGS as CategoryKey[];

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const activeSlug = slug as CategoryKey;
const active = categories[activeSlug];

if (!active) {
  return Astro.redirect("/404");
}

const articles: WebsiteArticle[] = await getPublishedArticlesByCategory(
  activeSlug,
  8,
);
const featuredArticle = articles[0] ?? null;
const moreArticles = articles.slice(1);
---

<ContentLayout
  title={active.name}
  description={active.metaDescription}
  canonicalUrl={`/category/${activeSlug}`}
>
  <div class="editorial-paper editorial-ink min-h-screen selection:bg-amber-200">
    <nav
      data-nav
      class="fixed inset-x-0 top-0 z-50 bg-transparent py-6 transition-all duration-500"
    >
      <div class="container mx-auto flex items-center justify-between px-6">
        <div class="flex items-center gap-8">
          <a
            href="/"
            class="flex items-center gap-1 font-sans text-3xl font-black leading-none tracking-[-0.02em]"
          >
            INSIGHT<span
              class="text-amber-600 underline decoration-2 underline-offset-4"
              >HUB</span
            >
          </a>

          <div
            class="hidden gap-8 font-sans text-[13px] font-semibold uppercase tracking-[0.22em] text-gray-500 lg:flex"
          >
            {(Object.keys(categories) as CategoryKey[]).map((key) => (
              <a
                href={`/category/${key}`}
                class={`transition-colors hover:text-amber-600 ${activeSlug === key ? "text-amber-600" : ""}`}
              >
                {categories[key].name}
              </a>
            ))}
          </div>
        </div>

        <div class="flex items-center gap-5">
          <button
            type="button"
            class="rounded-full p-2 transition-colors hover:bg-gray-100"
            aria-label="Search"
          >
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
          <button
            type="button"
            class="editorial-ink-bg hidden rounded-full px-8 py-3 font-sans text-[12px] font-bold tracking-[0.08em] text-white transition-all hover:bg-amber-600 md:block"
          >
            SUBSCRIBE
          </button>
          <button
            data-mobile-toggle
            type="button"
            class="lg:hidden"
            aria-expanded="false"
            aria-controls="mobile-category-nav"
            aria-label="Open menu"
          >
            <svg
              data-menu-icon
              class="h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <svg
              data-close-icon
              class="hidden h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <div
        id="mobile-category-nav"
        data-mobile-menu
        class="container mx-auto hidden px-6 pb-4 pt-4 lg:hidden"
      >
        <div
          class="rounded-2xl border border-gray-200 bg-white/95 p-4 shadow-sm backdrop-blur"
        >
          <div
            class="flex flex-col gap-4 font-sans text-xs font-semibold uppercase tracking-[0.2em] text-gray-700"
          >
            {(Object.keys(categories) as CategoryKey[]).map((key) => (
              <a
                href={`/category/${key}`}
                class={`transition-colors hover:text-amber-600 ${activeSlug === key ? "text-amber-600" : ""}`}
              >
                {categories[key].name}
              </a>
            ))}
            <a href="/about" class="transition-colors hover:text-amber-600"
              >About</a
            >
            <a href="/contact" class="transition-colors hover:text-amber-600"
              >Contact</a
            >
          </div>
        </div>
      </div>
    </nav>

    <header class="border-b border-gray-200 px-8 pb-20 pt-40">
      <div class="container mx-auto">
        <div
          class="relative flex flex-col items-baseline justify-between gap-8 lg:flex-row"
        >
          <div class="max-w-3xl">
            <div class="mb-6 flex items-center gap-3">
              <span class={`h-[1px] w-10 ${active.accentLine}`}></span>
              <span
                class={`font-sans text-[11px] font-black uppercase tracking-[0.4em] ${active.accentText}`}
              >
                {active.tagline}
              </span>
            </div>
            <h1
              class="mb-8 text-[clamp(3.6rem,8.5vw,7.5rem)] font-bold italic leading-[0.93] tracking-tight"
            >
              {active.name}.
            </h1>
            <p class="max-w-2xl text-xl font-light leading-relaxed text-gray-500 md:text-2xl">
              {active.description}
            </p>
          </div>
          <div
            class="pointer-events-none absolute right-8 top-0 hidden select-none text-[120px] opacity-[0.03] lg:block"
          >
            {active.icon}
          </div>
        </div>
      </div>
    </header>

    <section class="border-b border-gray-100 bg-white px-8 py-24">
      <div class="container mx-auto">
        {
          featuredArticle ? (
            <div class="grid items-center gap-16 lg:grid-cols-12">
              <a
                href={`/article/${featuredArticle.slug}`}
                class="group cursor-pointer overflow-hidden rounded-sm lg:col-span-7"
              >
                <img
                  src={featuredArticle.image}
                  alt={featuredArticle.title}
                  class="aspect-[16/10] w-full object-cover transition-transform duration-1000 group-hover:scale-105"
                />
              </a>

              <div class="lg:col-span-5">
                <div
                  class="mb-6 flex items-center gap-2 font-sans text-[10px] font-bold uppercase tracking-widest text-gray-400"
                >
                  <svg
                    class="h-[14px] w-[14px] text-amber-500"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5L12 3z"></path>
                  </svg>
                  Special Edition Article
                </div>
                <h2 class="mb-6 text-[clamp(2rem,3.8vw,3rem)] font-bold italic leading-[1.03] transition-colors hover:text-amber-700">
                  <a href={`/article/${featuredArticle.slug}`}>
                    {featuredArticle.title}
                  </a>
                </h2>
                <p class="mb-8 text-lg leading-relaxed text-gray-500">
                  {featuredArticle.excerpt}
                </p>
                <div class="flex items-center justify-between border-t border-gray-100 pt-8">
                  <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-gray-100"></div>
                    <span class="font-sans text-xs font-bold tracking-wider">
                      {featuredArticle.author}
                    </span>
                  </div>
                  <a
                    href={`/article/${featuredArticle.slug}`}
                    class="flex items-center gap-2 font-sans text-xs font-black uppercase tracking-widest transition-transform hover:translate-x-2"
                  >
                    Explore
                    <svg
                      class="h-4 w-4"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ) : (
            <div class="rounded-xl border border-dashed border-gray-300 px-8 py-16 text-center">
              <p class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
                No published content in this category yet.
              </p>
              <p class="mt-4 text-lg text-gray-500">
                Seed and publish articles in Supabase to populate this page.
              </p>
            </div>
          )
        }
      </div>
    </section>

    <section class="px-8 py-24">
      <div class="container mx-auto">
        <div class="mb-16 flex items-end justify-between">
          <div>
            <h3
              class="mb-2 font-sans text-[11px] font-black uppercase tracking-[0.4em] text-gray-300"
            >
              COLLECTION
            </h3>
            <h2 class="text-3xl font-bold">Latest Reports</h2>
          </div>
          <div class="hidden gap-4 md:flex">
            <button
              type="button"
              class="rounded-full border border-gray-200 p-3 transition-all hover:bg-black hover:text-white"
              aria-label="Previous"
            >
              <svg
                class="h-[18px] w-[18px]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
            </button>
            <button
              type="button"
              class="rounded-full border border-gray-200 p-3 transition-all hover:bg-black hover:text-white"
              aria-label="Next"
            >
              <svg
                class="h-[18px] w-[18px]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
          </div>
        </div>

        <div class="grid gap-x-12 gap-y-20 md:grid-cols-2 lg:grid-cols-3">
          {moreArticles.map((article) => (
            <article class="group cursor-pointer">
              <a href={`/article/${article.slug}`} class="block">
                <div class="relative mb-8 aspect-[4/5] overflow-hidden rounded-sm bg-gray-100">
                  <img
                    src={article.image}
                    alt={article.title}
                    class="h-full w-full object-cover grayscale transition-all duration-700 group-hover:scale-110 group-hover:grayscale-0"
                  />
                  <div
                    class="absolute bottom-6 left-6 opacity-0 transition-opacity group-hover:opacity-100"
                  >
                    <button
                      type="button"
                      class="rounded-full bg-white/90 p-3 shadow-xl backdrop-blur-sm"
                      aria-label="Bookmark"
                    >
                      <svg
                        class="h-[18px] w-[18px]"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                      >
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                      </svg>
                    </button>
                  </div>
                </div>
                <div
                  class="mb-4 flex items-center gap-4 font-sans text-[10px] font-bold uppercase tracking-widest text-gray-400"
                >
                  <span>{article.dateLabel}</span>
                  <span class="h-1 w-1 rounded-full bg-gray-300"></span>
                  <span>{article.readTimeLabel}</span>
                </div>
                <h4
                  class={`mb-4 text-2xl font-bold leading-tight decoration-2 underline-offset-8 group-hover:underline ${active.accentUnderline}`}
                >
                  {article.title}
                </h4>
                <p class="line-clamp-2 leading-relaxed text-gray-500">
                  {article.excerpt}
                </p>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-stone-900 py-32 text-white">
      <div class="container relative z-10 mx-auto px-8">
        <div class="max-w-4xl">
          <svg
            class="mb-8 text-amber-500"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <circle cx="12" cy="8" r="3"></circle>
            <path d="M14.5 17.5L12 15l-2.5 2.5-3.5-3.5L8.5 11.5 6 9l3.5-3.5L12 8l2.5-2.5L18 9l-2.5 2.5L18 14z"></path>
          </svg>
          <h2 class="mb-8 text-5xl font-bold italic leading-tight md:text-7xl">
            Become a Master of <br />
            <span
              class="not-italic underline decoration-amber-600 underline-offset-[12px]"
              >Your Environment.</span
            >
          </h2>
          <p class="mb-12 max-w-2xl text-xl font-light leading-relaxed text-stone-400">
            Access our full library of proprietary frameworks and executive
            reports designed for those who settle for nothing less than
            excellence.
          </p>
          <div class="flex flex-col gap-6 sm:flex-row">
            <button
              type="button"
              class="bg-amber-600 px-10 py-5 font-sans text-xs font-bold uppercase tracking-widest text-white transition-all hover:bg-amber-700"
            >
              Download Resource Library
            </button>
            <button
              type="button"
              class="border border-white/20 px-10 py-5 font-sans text-xs font-bold uppercase tracking-widest transition-all hover:bg-white hover:text-black"
            >
              Contact the Editors
            </button>
          </div>
        </div>
      </div>
      <div
        class="absolute right-0 top-0 h-full w-1/2 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-amber-900/10 via-transparent to-transparent"
      >
      </div>
    </section>

    <footer class="border-t border-gray-100 bg-white py-20">
      <div class="container mx-auto px-8 text-center">
        <p
          class="font-sans text-[10px] font-black uppercase tracking-[0.5em] text-gray-300"
        >
          InsightHub Editorial Group &bull; MMXXIV
        </p>
      </div>
    </footer>
  </div>

  <script is:inline>
    (() => {
      const nav = document.querySelector("[data-nav]");
      const toggle = document.querySelector("[data-mobile-toggle]");
      const menu = document.querySelector("[data-mobile-menu]");
      const menuIcon = toggle?.querySelector("[data-menu-icon]");
      const closeIcon = toggle?.querySelector("[data-close-icon]");

      if (nav) {
        const updateNav = () => {
          const scrolled = window.scrollY > 50;
          nav.classList.toggle("bg-white/80", scrolled);
          nav.classList.toggle("backdrop-blur-md", scrolled);
          nav.classList.toggle("py-3", scrolled);
          nav.classList.toggle("shadow-sm", scrolled);
          nav.classList.toggle("bg-transparent", !scrolled);
          nav.classList.toggle("py-6", !scrolled);
        };
        updateNav();
        window.addEventListener("scroll", updateNav, { passive: true });
      }

      if (toggle && menu && menuIcon && closeIcon) {
        const setOpen = (open) => {
          menu.classList.toggle("hidden", !open);
          menuIcon.classList.toggle("hidden", open);
          closeIcon.classList.toggle("hidden", !open);
          toggle.setAttribute("aria-expanded", open ? "true" : "false");
        };
        setOpen(false);
        toggle.addEventListener("click", () => {
          setOpen(toggle.getAttribute("aria-expanded") !== "true");
        });
      }
    })();
  </script>
</ContentLayout>
