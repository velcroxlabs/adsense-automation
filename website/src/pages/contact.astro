---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact"
  description="Get in touch with questions or feedback about our automated content system."
  noindex={true}
>
  <div class="container-narrow">
    <h1 class="text-4xl font-bold mb-6">Contact Us</h1>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <div class="prose prose-lg max-w-none mb-8">
          <p>
            This website is an experimental project demonstrating automated content generation technology. 
            We're exploring how AI can be used to create useful, SEO-optimized content at scale.
          </p>
          
          <h2>About This Project</h2>
          <p>
            AdSense Automation is a proof-of-concept system that:
          </p>
          <ul>
            <li>Automatically researches keywords and topics</li>
            <li>Generates articles using AI language models</li>
            <li>Optimizes content for search engines</li>
            <li>Publishes and monitors performance automatically</li>
          </ul>
          
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 my-6">
            <p class="text-blue-800">
              <strong>Note:</strong> This is an automated system. We don't have a traditional contact form, 
              but you can reach out through the methods below.
            </p>
          </div>
        </div>
        
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-xl font-bold mb-4">Technical Details</h3>
          <ul class="space-y-2">
            <li><strong>Framework:</strong> Astro (Static Site Generator)</li>
            <li><strong>Database:</strong> Supabase (PostgreSQL)</li>
            <li><strong>Hosting:</strong> Vercel</li>
            <li><strong>CI/CD:</strong> GitHub Actions</li>
            <li><strong>Content Generation:</strong> AI language models</li>
          </ul>
        </div>
      </div>
      
      <div>
        <div class="card">
          <h2 class="text-2xl font-bold mb-6">Ways to Connect</h2>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <span class="text-2xl">📧</span>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-semibold mb-1">Email</h3>
                <p class="text-gray-600">
                  For technical inquiries or collaboration proposals:
                </p>
                <p class="mt-2">
                  <code class="bg-gray-100 px-3 py-1 rounded text-sm">technical@adsense-auto.example.com</code>
                </p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <span class="text-2xl">🐙</span>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-semibold mb-1">GitHub</h3>
                <p class="text-gray-600">
                  This project is open-source. View the code, report issues, or contribute:
                </p>
                <p class="mt-2">
                  <code class="bg-gray-100 px-3 py-1 rounded text-sm">github.com/your-username/adsense-automation</code>
                </p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="flex-shrink-0 mt-1">
                <span class="text-2xl">📝</span>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-semibold mb-1">Feedback Form</h3>
                <p class="text-gray-600">
                  Share your thoughts on content quality, technical issues, or suggestions:
                </p>
                <div class="mt-4 space-y-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Your Email</label>
                    <input type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="you@example.com" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
                    <textarea rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Your feedback..."></textarea>
                  </div>
                  <button type="button" class="btn btn-primary w-full" disabled>
                    Submit Feedback (Demo)
                  </button>
                  <p class="text-sm text-gray-500 text-center">
                    This is a demo form. In a production system, this would connect to a backend.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="mt-8 p-6 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl">
          <h3 class="text-xl font-bold mb-3">Content Accuracy</h3>
          <p class="text-gray-700 mb-4">
            While we strive for accuracy, remember that content is AI-generated. Always verify important information with authoritative sources.
          </p>
          <div class="flex items-center text-sm text-gray-600">
            <span class="mr-2">🔍</span>
            <span>Articles are automatically checked for quality, but human review is recommended for critical topics.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>